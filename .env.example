# Turnitin Environment Configuration
# Copy this file to .env and fill in the values for your target environment.

# Environment name (matches Python -E flag): new_qa1, new_production, etc.
TII_ENVIRONMENT=new_qa1

# Base URLs
TII_URL=http://qa1-www.turnitin.com/
TII_LOGIN_URL=http://qa1-www.turnitin.com/login_page.asp?google_captcha_override=3D5CFEA66D40E5446A3EF7737398AC2E

# SDK Wrapper REST API
SDK_WRAPPER_URL=https://jenkins.turnitin.com/qa/sdkrest/generic_env.php/
SDK_WRAPPER_ACCOUNT_ID=82014
SDK_WRAPPER_TFSPLUS_ACCOUNT_ID=82680

# Panda APIs
PANDA_SUBMISSION_PURGE_URL=https://internal-qa.us2.turnitin.org/sms-namespace/seu/sms-serviceName/panda/submission/
PANDA_SUBMISSION_SEARCH_URL=https://qa1-www.turnitin.com/internalapi/objectinfo/v1/object/
PANDA_INSTITUTION_ID=58681

# Instructor credentials
INSTRUCTOR_USERNAME=qmm+tfs.instructor.all@turnitin.com
INSTRUCTOR_PASSWORD=Test1ng4life*

# Student credentials
STUDENT_USERNAME=qmm+tfs.student.01@turnitin.com
STUDENT_PASSWORD=test1ng4life
STUDENT_FIRSTNAME=Student 01
STUDENT_LASTNAME=TFS Automation

# Upload directory (absolute path to test documents)
UPLOAD_DIR=./src/documents/
