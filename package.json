{
  "name": "turnitin-tests-playwright",
  "version": "1.0.0",
  "description": "Turnitin E2E tests using Playwright (TypeScript)",
  "scripts": {
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:debug": "npx playwright test --debug",
    "test:graf": "npx playwright test instructor-graf",
    "test:submission": "npx playwright test instructor-submission"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^25.5.0",
    "dotenv": "^16.4.7",
    "typescript": "^6.0.2"
  }
}
